# Core
PROJECT_NAME=litellm-openrouter-demo
ENV=dev

# GLM (Zhipu) upstream
ZHIPU_API_KEY=your-zhipu-api-key

# DeepSeek upstream
DEEPSEEK_API_KEY=sk-your-deepseek-key

# Qwen (DashScope) upstream
DASHSCOPE_API_KEY=sk-your-dashscope-key

# Postgres
POSTGRES_DB=litellm_demo
POSTGRES_USER=litellm
POSTGRES_PASSWORD=litellm
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# Control-plane auth placeholder
CONTROL_PLANE_ADMIN_TOKEN=change-me

# LiteLLM runtime
LITELLM_MASTER_KEY=sk-demo-master-key
LITELLM_SALT_KEY=demo-salt-key-32-bytes-minimum

# LiteLLM admin API
LITELLM_BASE_URL=http://litellm:4000
